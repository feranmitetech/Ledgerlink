PORT=8787
PUBLIC_BASE_URL=https://your-ledgerlink-domain.example
APP_SECRET=replace_with_a_long_random_secret_at_least_32_characters
ADMIN_API_TOKEN=replace_with_a_different_long_random_admin_token

# Your LedgerLink SaaS billing Paystack key. Customers pay your platform this key for renewals.
PLATFORM_PAYSTACK_SECRET_KEY=sk_live_your_platform_billing_key
LEDGERLINK_MONTHLY_PRICE_KOBO=1200000
LEDGERLINK_BILLING_DAYS=30

DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Alternative hosted storage if Postgres is unavailable
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ledgerlink

# Local JSON fallback only, do not use on Render production
# DB_PATH=./data/ledgerlink-db.json

# Optional Paystack webhook router
LEDGERLINK_WEBHOOK_URL=https://your-ledgerlink-domain.example/paystack/webhook
OLD_PROJECT_WEBHOOK_URL=https://your-old-project.example/paystack/webhook
OLD_PROJECT_METADATA_KEY=project
OLD_PROJECT_METADATA_VALUE=old-project
